# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find all three in: Supabase dashboard → Project Settings → Database / API

# Session pooler URL — used by the running API server
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Direct connection URL — used ONLY for migrations (drizzle-kit migrate)
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[db-password]@db.[project-ref].supabase.co:5432/postgres

# Supabase project URL + keys (from API settings)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Never expose to client!

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-64-char-random-hex-string

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Solana (primary chain) ────────────────────────────────────────────────────
# Recommended: Helius (best DAS + NFT support)  https://helius.dev
# Free tier: 100k credits/day
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key-here

# ─── EVM chains (secondary) ───────────────────────────────────────────────────
ETH_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# ─── Internal ─────────────────────────────────────────────────────────────────
INTERNAL_SECRET=change-this-internal-secret
PORT=3001

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Mobile (Expo) ────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WS_URL=ws://localhost:3001/ws
EXPO_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
