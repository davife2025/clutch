{
  "manifest_version": 3,
  "name": "Clutch Wallet",
  "description": "Your Solana wallet pocket — always there. Connect to any Solana dApp directly from your browser.",
  "version": "1.0.0",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup":  "popup.html",
    "default_title":  "Clutch Wallet",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*"],
      "js":      ["content.js"],
      "run_at":  "document_start",
      "world":   "MAIN"
    }
  ],

  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://api.mainnet-beta.solana.com/*",
    "https://api.realms.today/*",
    "https://api.coingecko.com/*",
    "https://quote-api.jup.ag/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches":   ["https://*/*", "http://localhost/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
